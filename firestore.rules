rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['status', 'hostId', 'calledNumbers', 'wins', 'mode', 'playerCount'])
        && request.resource.data.status is string
        && request.resource.data.hostId is string
        && request.resource.data.calledNumbers is list
        && request.resource.data.calledNumbers.size() == 0;
      allow update: if request.resource.data.keys().hasAll(['status', 'hostId', 'calledNumbers', 'wins'])
        && request.resource.data.status is string
        && request.resource.data.hostId == resource.data.hostId
        && request.resource.data.calledNumbers is list
        && request.resource.data.calledNumbers.size() >= resource.data.calledNumbers.size();
      allow delete: if false;

      match /players/{playerId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['name', 'isBot', 'card', 'marked', 'claimedWins'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 50
          && request.resource.data.claimedWins is list;
        allow update: if request.resource.data.keys().hasAll(['name', 'isBot', 'card', 'marked', 'claimedWins'])
          && request.resource.data.name is string
          && request.resource.data.claimedWins is list;
        allow delete: if false;
      }
    }
  }
}
